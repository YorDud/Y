ORDER_SMTP_HOST=smtp.mail.ru
ORDER_SMTP_PORT=465
ORDER_SMTP_SECURE=true
ORDER_EMAIL=y.underwear.order@mail.ru
ORDER_EMAIL_PASSWORD=Erw4MUGEYUtDzDqDJH9D

# Официальная почта (письма клиентам)
CLIENT_SMTP_HOST=smtp.mail.ru
CLIENT_SMTP_PORT=465
CLIENT_SMTP_SECURE=true
CLIENT_EMAIL=y.underwear@mail.ru
CLIENT_EMAIL_PASSWORD=eoSDev1caQYrYo4F4roa

# =========================
